{
  "name": "apyee-protocol",
  "version": "1.0.0",
  "description": "Apyee Protocol — Non-custodial AI-powered stablecoin yield aggregator. ERC-4626 Vault contracts on Ethereum / Base / Arbitrum / BNB Chain.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/coinlive-apyee/apyee-protocol.git"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/*.test.ts",
    "test:vault": "hardhat test test/unit/Vault.test.ts",
    "test:invariant": "hardhat test test/invariant/*.test.ts",
    "test:fresh": "npm run clean && npm run compile && npm run test:unit",
    "test:gas": "REPORT_GAS=true hardhat test",
    "test:coverage": "hardhat coverage",
    "test:fork": "FORK=true hardhat test test/integration/*.test.ts",
    "test:fork:bsc": "FORK=true FORK_CHAIN=bsc hardhat test test/integration/*.test.ts",
    "clean": "hardhat clean",
    "lint": "solhint 'contracts/**/*.sol' && eslint '{test,scripts}/**/*.ts'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix && eslint '{test,scripts}/**/*.ts' --fix",
    "format": "prettier --write '{contracts,test,scripts}/**/*.{sol,ts}'",
    "format:check": "prettier --check '{contracts,test,scripts}/**/*.{sol,ts}'",
    "node": "hardhat node",
    "deploy:vault": "hardhat run scripts/deploy/01-deploy-vault.ts",
    "deploy:strategies": "hardhat run scripts/deploy/02-deploy-strategies.ts",
    "deploy:register": "hardhat run scripts/deploy/03-register-strategies.ts",
    "deploy:transfer-ownership": "hardhat run scripts/deploy/04-transfer-ownership.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-ignition": "^0.15.9",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.9",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.13",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "hardhat-gas-reporter": "^1.0.10",
    "prettier": "^3.4.2",
    "prettier-plugin-solidity": "^1.4.2",
    "solhint": "^5.0.4",
    "solidity-coverage": "^0.8.14",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0"
  }
}
