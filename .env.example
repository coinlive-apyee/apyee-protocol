# ─────────────────────────────────────────────────────────────
# Apyee Protocol — Environment Variables
# Copy to `.env` and fill in values. Never commit `.env`.
# Only needed for fork tests + deploy scripts; not required to run unit tests.
# ─────────────────────────────────────────────────────────────

# Deployer EOA — used only at deploy time; ownership transfers to Multi-sig in step 04.
DEPLOYER_PRIVATE_KEY=

# RPC — Alchemy (Ethereum / Base / Arbitrum)
# Sign up: https://dashboard.alchemy.com — free tier 15M CU/month
ALCHEMY_API_KEY=

# RPC — NodeReal MegaNode (BNB Chain only — Alchemy does not support BSC)
# Sign up: https://nodereal.io
# Format: https://bsc-mainnet.nodereal.io/v1/<API_KEY>
# Leave blank to fall back to public RPC (bsc-dataseed.binance.org)
NODEREAL_BNB_URL=

# Pin a block for mainnet fork tests (optional)
MAINNET_FORK_BLOCK=

# Fork mode (set true to enable fork-based integration tests)
FORK=false

# Explorer API keys (used by `hardhat verify` after deployment)
ETHERSCAN_API_KEY=

# Gas reporter (set true to print gas usage during tests)
REPORT_GAS=false

# ─────────────────────────────────────────────────────────────
# Deployment Roles (only required when running scripts/deploy/*)
# ─────────────────────────────────────────────────────────────

# Active generation. Selects which Keeper address to read below.
#   v1-prod / v2-prod → KEEPER_ADDRESS_PROD
#   v0-dev / v1-dev / v2-dev / unset → KEEPER_ADDRESS_DEV
APYEE_GENERATION=

# Keeper EOA — single address used by the Keeper service to call harvest /
# invest / divest. Same address across all chains; split by generation so
# prod and dev keys can be isolated for operational security.
KEEPER_ADDRESS_DEV=
KEEPER_ADDRESS_PROD=

# Single EOA authorized to call pause(). Single-purpose key.
GUARDIAN_ADDRESS=

# Per-chain Multi-sig addresses. Vault ownership transfers to these in step 04.
MULTISIG_MAINNET=
MULTISIG_BASE=
MULTISIG_ARBITRUM=
MULTISIG_BSC=

# Treasury (where streaming fee mints fee shares). Defaults to MULTISIG_<NETWORK> if blank.
TREASURY_MAINNET=
TREASURY_BASE=
TREASURY_ARBITRUM=
TREASURY_BSC=
